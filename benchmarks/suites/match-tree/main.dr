enum Node {
    Leaf(i32),
    Pair(Node, Node),
}

fun sum(node: Node): i32 {
    match node {
        Node::Leaf(value) => value,
        Node::Pair(left, right) => sum(left) + sum(right),
    }
}

fun main(): i32 {
    const tree = Node::Pair(
        Node::Pair(Node::Leaf(1), Node::Leaf(2)),
        Node::Pair(Node::Leaf(3), Node::Leaf(4)),
    );
    sum(tree)
}
