/// std.crypto — cryptographic primitives.
///
/// All operations in this module require a `CryptoCap` capability token.
/// This enforces that cryptographic operations are intentional and auditable.
///
/// # Security notes
/// - Comparison of MACs/digests must use `constant_time_eq` to prevent
///   timing attacks.
/// - Random bytes come from the OS CSPRNG (`/dev/urandom` on Unix,
///   `BCryptGenRandom` on Windows); they are never seeded with system time.
/// - Secret keys are zeroed from memory when dropped.
///
/// EXPERIMENTAL: this module is not runtime-complete yet. APIs backed by
/// `todo!()` are intentionally unstable and must not be treated as production-ready.

import { Result, Option, String } from "std/core";
import { Vec } from "std/collections";

// ─── Capability ───────────────────────────────────────────────────────────────

/// Capability token that gates all cryptographic operations.
/// Only the runtime can produce a `CryptoCap`; user code receives one
/// through the program's capability tree.
export struct CryptoCap {
    _priv: (),
}

// ─── Constant-time comparison ─────────────────────────────────────────────────

/// Compare two byte slices in constant time (prevents timing attacks).
/// Returns `true` if and only if the slices are equal in length and content.
export fun constant_time_eq(a: &[u8], b: &[u8]): bool {
    if a.len() != b.len() { return false; }
    const diff = 0u8;
    for i in 0..a.len() {
        diff |= a[i] ^ b[i];
    }
    diff == 0
}

