// ─── Symmetric encryption (AES-GCM) ──────────────────────────────────────────

/// A 256-bit AES-GCM secret key. Zeroed from memory on drop.
export struct Aes256GcmKey {
    _bytes: [u8; 32],
}

extend Aes256GcmKey {
    /// Generate a fresh random key.
    export fun generate(_cap: &CryptoCap): Aes256GcmKey { todo!() }

    /// Wrap an existing 32-byte key. Returns `Err` if the slice is not exactly
    /// 32 bytes.
    export fun from_bytes(_cap: &CryptoCap, bytes: &[u8]): Result<Aes256GcmKey, String> {
        if bytes.len() != 32 {
            return Result::Err(String::from("AES-256-GCM key must be 32 bytes"));
        }
        todo!()
    }
}

/// A 96-bit (12-byte) nonce for AES-GCM. Must be unique per (key, message) pair.
export struct Nonce {
    _bytes: [u8; 12],
}

extend Nonce {
    /// Generate a random nonce.
    export fun random(_cap: &CryptoCap): Nonce { todo!() }

    /// Construct from a fixed 12-byte array.
    export fun from_bytes(bytes: [u8; 12]): Nonce { Nonce { _bytes: bytes } }
}

/// Encrypt `plaintext` with AES-256-GCM.
