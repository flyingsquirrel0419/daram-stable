export fun aes256_gcm_encrypt(
    _cap: &CryptoCap,
    key: &Aes256GcmKey,
    nonce: &Nonce,
    plaintext: &[u8],
    aad: &[u8],
): Vec<u8> {
    todo!()
}

/// Decrypt and verify `ciphertext` (with appended 16-byte tag) using AES-256-GCM.
