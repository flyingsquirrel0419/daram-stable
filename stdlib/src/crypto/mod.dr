// ─── Hashing ──────────────────────────────────────────────────────────────────

/// The SHA-256 digest algorithm (32-byte output).
export struct Sha256 {
    _state: [u32; 8],
    _buf: [u8; 64],
    _buf_len: usize,
    _total: u64,
}

extend Sha256 {
    export fun new(): Sha256 {
        todo!()
    }

    export fun update(mut self, data: &[u8]): Sha256 {
        todo!()
    }

    export fun finalize(self): [u8; 32] {
        todo!()
    }
}

/// Compute SHA-256 of `data` in one shot.
export fun sha256(data: &[u8]): [u8; 32] {
    Sha256::new().update(data).finalize()
}

/// The SHA-512 digest algorithm (64-byte output).
export struct Sha512 {
    _state: [u64; 8],
    _buf: [u8; 128],
    _buf_len: usize,
    _total: u128,
}

extend Sha512 {
    export fun new(): Sha512 { todo!() }
    export fun update(mut self, data: &[u8]): Sha512 { todo!() }
    export fun finalize(self): [u8; 64] { todo!() }
}

/// Compute SHA-512 of `data` in one shot.
export fun sha512(data: &[u8]): [u8; 64] {
    Sha512::new().update(data).finalize()
}

/// The BLAKE3 hash function (32-byte output, extremely fast).
export struct Blake3 {
    _inner: [u8; 64],
}

extend Blake3 {
    export fun new(): Blake3 { todo!() }
    export fun update(mut self, data: &[u8]): Blake3 { todo!() }
    export fun finalize(self): [u8; 32] { todo!() }
    /// Produce an output digest of arbitrary length.
    export fun finalize_xof(self, len: usize): Vec<u8> { todo!() }
}

/// Compute BLAKE3 of `data` in one shot.
export fun blake3(data: &[u8]): [u8; 32] {
    Blake3::new().update(data).finalize()
}

// ─── HMAC ─────────────────────────────────────────────────────────────────────

/// HMAC-SHA-256 message authentication code (32-byte tag).
export struct HmacSha256 {
    _ipad: Sha256,
    _opad_key: [u8; 64],
}

extend HmacSha256 {
    export fun new(_cap: &CryptoCap, key: &[u8]): HmacSha256 { todo!() }
    export fun update(mut self, data: &[u8]): HmacSha256 { todo!() }
    export fun finalize(self): [u8; 32] { todo!() }

    /// Verify a MAC tag in constant time.
    export fun verify(self, tag: &[u8; 32]): bool {
        constant_time_eq(&self.finalize(), tag)
    }
}

/// Compute HMAC-SHA-256 in one shot.
export fun hmac_sha256(_cap: &CryptoCap, key: &[u8], data: &[u8]): [u8; 32] {
    HmacSha256::new(_cap, key).update(data).finalize()
}

