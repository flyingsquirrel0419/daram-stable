}

// ─── Hex encoding helpers ─────────────────────────────────────────────────────

const HEX_CHARS: &[u8; 16] = b"0123456789abcdef";

/// Encode a byte slice as a lowercase hex string.
export fun hex_encode(bytes: &[u8]): String {
    const s = String::new();
    for b in bytes {
        s.push(HEX_CHARS[(b >> 4) as usize] as char);
        s.push(HEX_CHARS[(b & 0x0f) as usize] as char);
    }
    s
}

/// Decode a lowercase or uppercase hex string into bytes.
/// Returns `Err` if the string has an odd length or invalid hex characters.
export fun hex_decode(s: &str): Result<Vec<u8>, String> {
    if s.len() % 2 != 0 {
        return Result::Err(String::from("hex string has odd length"));
    }
    const bytes = s.as_bytes();
    const out = Vec::new();
    const i = 0;
    while i < bytes.len() {
        const hi = hex_nibble(bytes[i])?;
        const lo = hex_nibble(bytes[i + 1])?;
        out.push((hi << 4) | lo);
        i += 2;
    }
    Result::Ok(out)
}

fun hex_nibble(b: u8): Result<u8, String> {
    match b {
        b'0'..=b'9' => Result::Ok(b - b'0'),
        b'a'..=b'f' => Result::Ok(b - b'a' + 10),
        b'A'..=b'F' => Result::Ok(b - b'A' + 10),
        _ => Result::Err(String::from("invalid hex character")),
    }
}

